# Recipe API — environment template
#
# Copy to .env in this directory (backend/):
#   cp .env.example .env
#
# Used by: FastAPI (src.core.config), Alembic (migrations/env.py), scripts.
# Frontend dev server usually needs no .env (Vite proxies /api → localhost:8000).

# --- Required ---

# PostgreSQL connection string (Supabase: Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Supabase project URL (https://YOUR_PROJECT_REF.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — Project Settings → API
SUPABASE_KEY=your-anon-key

# Supabase service role key (server-side only; never expose to the browser)
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Security ---

# JWT signing secret — use a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Optional JWT tuning (defaults in src/core/config.py)
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- OpenAI (tag suggestions, NL search, nutrition; optional) ---

# OPENAI_API_KEY=sk-...
# OPENAI_ORG_ID=

# Optional overrides (defaults exist in settings)
# OPENAI_DEFAULT_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=1000
# OPENAI_TEMPERATURE=0.7

# --- Optional ---
# See src/core/config.py for PROJECT_NAME, BACKEND_CORS_ORIGINS, and other env-overridable defaults.
