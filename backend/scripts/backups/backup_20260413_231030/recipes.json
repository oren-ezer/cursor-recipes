    "title": "\u05e1\u05e4\u05d2\u05d8\u05d9 \u05d1\u05d5\u05dc\u05d5\u05e0\u05d6",
    "description": "\u05de\u05d0\u05db\u05dc \u05e4\u05e1\u05d8\u05d4 \u05de\u05e1\u05d5\u05e8\u05ea\u05d9 ",
    "ingredients": [
      {
        "name": "\u05e4\u05e1\u05d8\u05d4 \u05d9\u05d1\u05e9\u05d4",
        "amount": "500 \u05d2\u05e8"
      },
      {
        "name": "\u05d1\u05d5\u05dc\u05d5\u05e0\u05d6 \u05e7\u05e4\u05d5\u05d0",
        "amount": "\u05e7\u05d5\u05e4\u05e1\u05d0"
      },
      {
        "name": "\u05e4\u05e8\u05de\u05d6\u05df \u05de\u05d2\u05d5\u05e8\u05e8",
        "amount": "2-3 \u05d7\u05d5\u05e4\u05e0\u05d9\u05dd"
      },
      {
        "name": "\u05de\u05dc\u05d7",
        "amount": "3 \u05db\u05e4\u05d5\u05ea"
      }
    ],
    "instructions": [
      "\u05dc\u05d4\u05e8\u05ea\u05d9\u05d7 \u05de\u05d9\u05dd \u05e2\u05dd \u05de\u05dc\u05d7",
      "\u05dc\u05d6\u05e8\u05d5\u05e7 \u05e4\u05e1\u05d8\u05d4 \u05dc\u05de\u05d9\u05dd \u05d5\u05dc\u05e2\u05e8\u05d1\u05d1 \u05de\u05d9\u05d3\u05d9 \u05e4\u05e2\u05dd",
      "\u05d1\u05de\u05e7\u05d1\u05d9\u05dc \u05dc\u05d4\u05e4\u05e9\u05d9\u05e8 \u05d1\u05d5\u05dc\u05d5\u05e0\u05d6",
      "\u05db\u05e9\u05d4\u05e4\u05e1\u05d8\u05d4 \u05de\u05d5\u05db\u05e0\u05d4 (\u05e2\u05dc \u05e4\u05d9 \u05d4\u05d5\u05e8\u05d0\u05d5\u05ea \u05d4\u05d9\u05e6\u05e8\u05df \u05d0\u05d5 \u05e2\u05dc \u05e4\u05d9 \u05d8\u05e2\u05d9\u05de\u05d4) \u05dc\u05d4\u05d5\u05e6\u05d9\u05d0 \u05de\u05d4\u05de\u05d9\u05dd \u05d5\u05d8\u05dc\u05e2\u05e8\u05d1\u05d1 \u05e2\u05dd \u05d4\u05d1\u05d5\u05dc\u05d5\u05e0\u05d6 \u05d4\u05d7\u05dd \u05e2\u05dc \u05d0\u05e9 \u05dc\u05d0 \u05d7\u05d6\u05e7\u05d4",
      "\u05dc\u05e4\u05d6\u05e8 \u05d0\u05ea \u05d4\u05e4\u05e8\u05de\u05d6\u05df , \u05dc\u05d4\u05d5\u05e1\u05d9\u05e3 \u05de\u05e2\u05d8 \u05de\u05de\u05d9 \u05d4\u05d1\u05d9\u05e9\u05d5\u05dc \u05d5\u05dc\u05e2\u05e8\u05d1 \u05d4\u05d9\u05d8\u05d1 \u05db\u05de\u05d4 \u05d3\u05e7\u05d5\u05ea",
      "\u05dc\u05d4\u05d2\u05d9\u05e9 \u05de\u05d9\u05d3",
      "\u05e0\u05d9\u05ea\u05df \u05dc\u05d7\u05de\u05dd \u05d1\u05de\u05d9\u05e7\u05e8\u05d5 \u05dc\u05d0\u05d7\u05e8 \u05e9\u05d4\u05d9\u05d4 \u05d1\u05de\u05e7\u05e8\u05e8"
    ],
